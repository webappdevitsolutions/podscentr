# Razorpay keys — get these from https://dashboard.razorpay.com/app/keys
# Never commit real keys to git. Set these in Vercel's Environment Variables panel instead.

# Public key — safe to expose in the browser, used by the checkout widget
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# Secret key — server-side only, NEVER expose this to the browser or commit it
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
